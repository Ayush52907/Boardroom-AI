# ===========================================================================
# Gemma Boardroom — Environment Variables
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local to git.
# ===========================================================================

# --- Supabase ---
# Get these from: https://supabase.com/dashboard → your project → Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# --- Gemini (Google AI Studio) ---
# Get your key from: https://aistudio.google.com/app/apikey
# This is SERVER-ONLY — never prefix with VITE_ or it will be exposed to the browser.
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MAX_RPM=30


# --- Legacy: Lovable Gateway (not needed for local dev) ---
# Only required when deploying through the Lovable platform.
# Leave blank for local development — Gemini SDK is used instead.
# LOVABLE_API_KEY=
